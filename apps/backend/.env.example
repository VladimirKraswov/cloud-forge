PORT=3000
PUBLIC_BASE_URL=https://api.cloud-forge.ru
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=cloud-forge
PUBLISHED_WORKER_IMAGE=xproger/cloud-forge-worker
PUBLISHED_WORKER_TAG=latest
WORKER_ASSETS_PATH=/app/worker
NPM_NETWORK=nginx-proxy-manager_default
